<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:title="@string/app_name"/>

    <!-- Barra de favoritos -->
    <LinearLayout
        android:id="@+id/favoritesBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        android:background="#F5F5F5"
        android:padding="4dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/favorites_label"
            android:textStyle="bold"
            android:paddingEnd="8dp"/>

        <!-- 5 slots de favoritos -->
        <ImageView
            android:id="@+id/favorite1"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:background="#DDDDDD"
            android:contentDescription="@string/favorite_slot"/>

        <ImageView
            android:id="@+id/favorite2"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:background="#DDDDDD"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/favorite_slot"/>

        <ImageView
            android:id="@+id/favorite3"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:background="#DDDDDD"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/favorite_slot"/>

        <ImageView
            android:id="@+id/favorite4"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:background="#DDDDDD"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/favorite_slot"/>

        <ImageView
            android:id="@+id/favorite5"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:padding="2dp"
            android:scaleType="centerCrop"
            android:background="#DDDDDD"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/favorite_slot"/>

    </LinearLayout>

    <!-- Indicador de carregamento -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <!-- Lista de imagens com SwipeRefresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Botão de refresh -->
    <Button
        android:id="@+id/refreshButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/refresh_button"/>

</LinearLayout>